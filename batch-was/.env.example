# =============================================================
# 환경변수 설정 예시
#
# 사용 방법:
#   1. 이 파일을 복사하여 .env 로 저장 (git 추적 제외됨)
#   2. admin/.env 와 동일한 DB 접속 정보를 입력
#   3. IDE Run Configuration → Environment variables 에 등록하거나
#      터미널: export $(cat .env | xargs) && ./mvnw spring-boot:run
# =============================================================

# === Database (Admin과 동일한 Oracle DB) ===
DB_URL=jdbc:oracle:thin:@localhost:1521:XE
DB_USERNAME=your_username
DB_PASSWORD=your_password
DB_SCHEMA=YOUR_SCHEMA

# === Batch WAS HTTP 엔드포인트 인증 ===
# POST /api/batch/execute 직접 호출 시 필요한 API Key
# Admin-WAS 간 TCP 통신에는 적용되지 않음 (내부망 격리로 보호)
# 미설정 시 인증 비활성화 (개발 환경용)
BATCH_WAS_API_KEY=your-api-key-here

# === 알림 설정 (Slack / Email) ===
# Slack Incoming Webhook URL (미설정 시 Slack 알림 생략)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
# 수신 이메일 주소 (미설정 시 Email 알림 생략)
NOTIFICATION_EMAIL_TO=batch-alert@your-company.com
# SMTP 설정 (미설정 시 Email 알림은 로그 출력으로 대체 — Mock 모드)
# spring.mail.host(SMTP_HOST) 설정 시 Spring Boot가 JavaMailSender를 자동 등록하여 실 발송으로 전환
SMTP_HOST=smtp.your-company.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# === Redis (분산 락 — Quartz 멀티 인스턴스 중복 실행 방지) ===
# docker-compose.yml의 redis 컨테이너 기본값
REDIS_HOST=localhost
REDIS_PORT=6379
