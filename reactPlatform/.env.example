# =============================================================
# 환경변수 설정 예시
#
# 사용 방법:
#   1. 이 파일을 복사하여 .env 로 저장 (git 추적 제외됨)
#   2. 아래 값을 실제 환경 정보로 채워 넣기
#   3. IDE 또는 터미널에서 .env 를 로드한 뒤 애플리케이션 실행
#
# .env 로드 방법:
#   - IntelliJ: EnvFile 플러그인 또는 Run Configuration → Environment variables
#   - 터미널: source .env && mvn spring-boot:run (bash)
# =============================================================

# === Database (Oracle) ===
DB_URL=jdbc:oracle:thin:@localhost:1521:XE
DB_USERNAME=your_username
DB_PASSWORD=your_password
DB_SCHEMA=YOUR_SCHEMA

# === App ===
APP_TITLE=Spider React Platform

# === Security ===
REMEMBER_ME_KEY=your-remember-me-secret
AUTHORITY_SOURCE=user-menu

# === Log Destinations ===
LOG_DEST_CONSOLE=true
LOG_DEST_H2=false
LOG_DEST_LOGSTASH=false
LOG_DEST_RDB_ACCESS=true
LOG_DEST_RDB_ERROR=true
LOGSTASH_HOST=localhost
LOGSTASH_PORT=5000

# === Figma API (React Generate — 디자인 노드 조회) ===
# Figma 계정 → Settings → Security → Personal access tokens 에서 발급
FIGMA_ACCESS_TOKEN=figd_...

# === Claude API (React Generate — React 코드 생성) ===
CLAUDE_API_KEY=sk-ant-api03-...

# === React Deploy (승인 후 배포 전략) ===
# mode: local  — 서버 로컬 파일시스템에 직접 기록 (개발 환경 기본값)
# mode: git-pr — GitHub 레포에 브랜치 생성 + PR 자동 생성 (스테이징/운영)
REACT_DEPLOY_MODE=local

# --- local 모드 경로 설정 ---
# 미설정 시 application.yml 기본값(../demo/front/src/reactplatform/generated, ../demo/front/src/reactplatform/containers) 사용
# REACT_DEPLOY_LOCAL_COMPONENT_DIR=../demo/front/src/reactplatform/generated
# REACT_DEPLOY_LOCAL_CONTAINER_DIR=../demo/front/src/reactplatform/containers

# --- git-pr 모드 설정 (REACT_DEPLOY_MODE=git-pr 일 때만 필요) ---
# GitHub Personal Access Token: repo 쓰기 권한 필요
# 발급: https://github.com/settings/tokens → Generate new token → repo 체크
GITHUB_TOKEN=ghp_...
# 대상 레포 소유자 (조직명 또는 개인 계정명)
GITHUB_REPO_OWNER=your-org-or-username
# 대상 레포 이름
GITHUB_REPO_NAME=your-repo-name
# PR 대상 브랜치 (미설정 시 main)
# GITHUB_BASE_BRANCH=main
# 레포 내 UI 컴포넌트 저장 경로
# 같은 모노레포(POC_HNC) 대상 시: demo/front/src/reactplatform/generated
# 프론트 전용 분리 레포 대상 시: src/reactplatform/generated
GITHUB_COMPONENT_PATH=demo/front/src/reactplatform/generated
# 레포 내 Container scaffold 저장 경로
# 같은 모노레포(POC_HNC) 대상 시: demo/front/src/reactplatform/containers
# 프론트 전용 분리 레포 대상 시: src/reactplatform/containers
GITHUB_CONTAINER_PATH=demo/front/src/reactplatform/containers
