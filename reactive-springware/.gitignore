# 의존성
node_modules/

# 빌드 산출물
dist/
storybook-static/

# component-library/dist/styles.css는 소비자 프로젝트가 직접 참조하므로 버전 관리
!component-library/dist/
component-library/dist/*
!component-library/dist/styles.css

# figma-plugin/dist/main.js는 Figma 플러그인 번들 — 버전 관리
!figma-plugin/dist/
figma-plugin/dist/*
!figma-plugin/dist/main.js

# 환경 변수
.env
.env.local
.env.*.local
design-tokens/.env.example

# 에디터
.DS_Store
*.log
.idea/*

#local
.claude/settings.local.json