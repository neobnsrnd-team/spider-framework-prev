# 이 파일을 복사해 demo/.env 를 만든 뒤 docker compose up --build 한다.
#   cp .env.example .env
# demo/.env 는 .gitignore 대상이라 커밋되지 않는다.

# === NAS Oracle DB (DDL/시드 적용 완료 전제) ===
DB_URL=jdbc:oracle:thin:@neobns.com:11521:XE
DB_USERNAME=D_SPIDERLINK
DB_PASSWORD=spider99!
DB_SCHEMA=D_SPIDERLINK

# === JWT (운영 시 32자 이상 임의 문자열로 교체) ===
JWT_SECRET=dev-secret-key-that-is-long-enough-for-hmac-256
JWT_REFRESH_SECRET=dev-refresh-secret-key-that-is-long-enough
JWT_ACCESS_EXPIRES_IN=1800000
JWT_REFRESH_EXPIRES_IN=604800000

# === Admin → biz-channel 공지 인증키 ===
ADMIN_SECRET=admin-secret
