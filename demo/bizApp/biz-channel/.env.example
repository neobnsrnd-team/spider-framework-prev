# Database
DB_URL=jdbc:oracle:thin:@localhost:1521:XE
DB_USERNAME=
DB_PASSWORD=

# HTTP Server
SERVER_PORT=18080

# Admin → biz-channel 공지 커맨드 수신용 내장 TCP 서버
TCP_SERVER_PORT=19400
TCP_SERVER_HANDLER_POOL_SIZE=5
TCP_SERVER_QUEUE_CAPACITY=20

# biz-auth connection
BIZ_AUTH_HOST=localhost
BIZ_AUTH_PORT=19100

# biz-transfer connection
BIZ_TRANSFER_HOST=localhost
BIZ_TRANSFER_PORT=19200

# JWT (HMAC-SHA256 secret keys — fill in with actual values)
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=1800000
JWT_REFRESH_EXPIRES_IN=604800000

# Admin API secret
ADMIN_SECRET=
