# ============================================================================
# react-cms — 환경 변수 설정
# ============================================================================
#
# 로컬 개발 환경 세팅:
#   1. 이 파일을 복사하여 .env 파일 생성: cp .env.example .env
#   2. Oracle Instant Client 설치 필요 (oracledb Thick 모드)
#   3. 아래 Oracle DB 계정 정보 입력 후 npm run dev 실행
#
# ============================================================================

# ── CMS 브랜드 테마 ──
# CMS 빌더 셸의 색상 테마를 지정합니다.
# 허용값: hana | kb | ibk | woori | shinhan | nh
# 미설정 시 기본값: hana
VITE_CMS_BRAND=hana

# ── Oracle DB (필수) ──
# 페이지 저장/로드 등 모든 CMS 데이터를 Oracle DB에서 관리.
ORACLE_USER=
ORACLE_PASSWORD=
ORACLE_HOST=
ORACLE_PORT=1521
ORACLE_SERVICE=XE
ORACLE_SCHEMA=

# Instant Client 설치 경로 (Windows에서 PATH 인식 문제 시 직접 지정)
# 예: ORACLE_CLIENT_DIR=C:/oracle/instantclient_21_3
ORACLE_CLIENT_DIR=

# ── CMS 인증 ──
# Spider Admin API 기반 인증 구조. 자세한 내용은 src/admin/current-user.ts 참고.

# 개발용 인증 우회 모드.
# true로 설정하면 Spider Admin API 호출 없이 쿠키(cms_bypass_role)로 역할을 분기한다.
#   cms_bypass_role=react-adm  → 관리자 권한 (REACT-CMS:R, REACT-CMS:W)
#   cms_bypass_role 미설정     → 일반 사용자 권한 (REACT-CMS:R, REACT-CMS:W)
# 운영 환경에서는 반드시 false로 유지해야 한다.
AUTH_BYPASS=false

# Spider Admin API 베이스 URL.
# AUTH_BYPASS=false(운영) 환경에서 /api/auth/me 호출에 사용된다.
# 예: SPIDER_ADMIN_API_URL=http://localhost:8080
SPIDER_ADMIN_API_URL=
