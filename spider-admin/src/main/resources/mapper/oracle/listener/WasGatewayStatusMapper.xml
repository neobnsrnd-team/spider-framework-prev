<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.admin_demo.domain.listener.mapper.WasGatewayStatusMapper">

    <resultMap id="GatewayStatusResultMap" type="com.example.admin_demo.domain.listener.dto.WasGatewayStatusResponse">
        <result property="instanceId" column="INSTANCE_ID"/>
        <result property="instanceName" column="INSTANCE_NAME"/>
        <result property="instanceType" column="INSTANCE_TYPE"/>
        <result property="instanceIp" column="INSTANCE_IP"/>
        <result property="instancePort" column="INSTANCE_PORT"/>

        <result property="gwId" column="GW_ID"/>
        <result property="gwName" column="GW_NAME"/>
        <result property="gwProperties" column="GW_PROPERTIES"/>
        <result property="threadCount" column="THREAD_COUNT"/>
        <result property="ioType" column="IO_TYPE"/>

        <result property="wasInstanceStatus" column="WAS_INSTANCE_STATUS"/>
        <result property="activeCountIdle" column="ACTIVE_COUNT_IDLE"/>
        <result property="lastUpdateDtime" column="LAST_UPDATE_DTIME"/>

        <result property="systemId" column="SYSTEM_ID"/>
        <result property="operModeType" column="OPER_MODE_TYPE"/>
        <result property="systemIp" column="SYSTEM_IP"/>
        <result property="systemPort" column="SYSTEM_PORT"/>
        <result property="stopYn" column="STOP_YN"/>
        <result property="systemDesc" column="SYSTEM_DESC"/>
        <result property="appliedWasInstance" column="APPLIED_WAS_INSTANCE"/>
    </resultMap>

    <sql id="GatewayStatusColumns">
        i.INSTANCE_ID,
        i.INSTANCE_NAME,
        i.INSTANCE_TYPE,
        i.IP AS INSTANCE_IP,
        i.PORT AS INSTANCE_PORT,
        l.WAS_INSTANCE_STATUS,
        l.ACTIVE_COUNT_IDLE,
        l.LAST_UPDATE_DTIME,
        g.GW_ID,
        g.GW_NAME,
        g.GW_PROPERTIES,
        g.THREAD_COUNT,
        g.IO_TYPE,
        s.SYSTEM_ID,
        s.OPER_MODE_TYPE,
        s.IP AS SYSTEM_IP,
        s.PORT AS SYSTEM_PORT,
        s.STOP_YN,
        s.SYSTEM_DESC,
        s.APPLIED_WAS_INSTANCE
    </sql>

    <sql id="GatewayStatusJoins">
        FROM FWK_WAS_LISTENER l
        JOIN FWK_WAS_INSTANCE i ON i.INSTANCE_ID = l.INSTANCE_ID
        JOIN FWK_GATEWAY g ON g.GW_ID = l.GW_ID
        JOIN FWK_SYSTEM s ON s.GW_ID = l.GW_ID AND s.SYSTEM_ID = l.SYSTEM_ID
        <where>
            <if test="instanceId != null and instanceId != ''">
                AND l.INSTANCE_ID LIKE '%' || #{instanceId} || '%'
            </if>
            <if test="gwId != null and gwId != ''">
                AND l.GW_ID LIKE '%' || #{gwId} || '%'
            </if>
            <if test="operModeType != null and operModeType != ''">
                AND s.OPER_MODE_TYPE = #{operModeType}
            </if>
            <if test="stopYn != null and stopYn != ''">
                AND s.STOP_YN = #{stopYn}
            </if>
        </where>
    </sql>

    <select id="findBySearch" resultMap="GatewayStatusResultMap">
        <bind name="orderColumn" value="
            (sortBy == 'instanceName') ? 'i.INSTANCE_NAME' :
            (sortBy == 'instanceType') ? 'i.INSTANCE_TYPE' :
            (sortBy == 'instanceIp') ? 'i.IP' :
            (sortBy == 'instancePort') ? 'i.PORT' :
            (sortBy == 'gwName') ? 'g.GW_NAME' :
            (sortBy == 'gwProperties') ? 'g.GW_PROPERTIES' :
            (sortBy == 'threadCount') ? 'g.THREAD_COUNT' :
            (sortBy == 'ioType') ? 'g.IO_TYPE' :
            (sortBy == 'operModeType') ? 's.OPER_MODE_TYPE' :
            (sortBy == 'systemIp') ? 's.IP' :
            (sortBy == 'systemPort') ? 's.PORT' :
            (sortBy == 'stopYn') ? 's.STOP_YN' :
            (sortBy == 'systemDesc') ? 's.SYSTEM_DESC' :
            (sortBy == 'wasInstanceStatus') ? 'l.WAS_INSTANCE_STATUS' :
            (sortBy == 'activeCountIdle') ? 'l.ACTIVE_COUNT_IDLE' :
            (sortBy == 'lastUpdateDtime') ? 'l.LAST_UPDATE_DTIME' :
            'i.INSTANCE_ID'
        "/>
        <bind name="orderDir" value="(sortDirection != null &amp;&amp; sortDirection.toUpperCase() == 'DESC') ? 'DESC' : 'ASC'"/>
        SELECT * FROM (
            SELECT
                <include refid="GatewayStatusColumns"/>,
                ROW_NUMBER() OVER (ORDER BY ${orderColumn} ${orderDir}) AS RN
            <include refid="GatewayStatusJoins"/>
        )
        WHERE RN BETWEEN #{offset} + 1 AND #{offset} + #{limit}
        ORDER BY RN
    </select>

    <select id="countBySearch" resultType="long">
        SELECT COUNT(*)
        <include refid="GatewayStatusJoins"/>
    </select>

    <select id="findDistinctInstances" resultType="com.example.admin_demo.domain.listener.dto.SimpleResponse">
        SELECT DISTINCT
            i.INSTANCE_ID AS value,
            NVL(i.INSTANCE_NAME, i.INSTANCE_ID) AS label
        FROM FWK_WAS_LISTENER l
        JOIN FWK_WAS_INSTANCE i ON i.INSTANCE_ID = l.INSTANCE_ID
        ORDER BY i.INSTANCE_ID
    </select>

    <select id="findDistinctGateways" resultType="com.example.admin_demo.domain.listener.dto.SimpleResponse">
        SELECT DISTINCT
            g.GW_ID AS value,
            NVL(g.GW_NAME, g.GW_ID) AS label
        FROM FWK_WAS_LISTENER l
        JOIN FWK_GATEWAY g ON g.GW_ID = l.GW_ID
        ORDER BY g.GW_ID
    </select>

    <select id="findDistinctOperModes" resultType="string">
        SELECT DISTINCT s.OPER_MODE_TYPE
        FROM FWK_WAS_LISTENER l
        JOIN FWK_SYSTEM s ON s.GW_ID = l.GW_ID AND s.SYSTEM_ID = l.SYSTEM_ID
        WHERE s.OPER_MODE_TYPE IS NOT NULL
        ORDER BY s.OPER_MODE_TYPE
    </select>

    <select id="findAllForExport" resultMap="GatewayStatusResultMap">
        <bind name="orderColumn" value="
            (sortBy == 'instanceName') ? 'i.INSTANCE_NAME' :
            (sortBy == 'instanceType') ? 'i.INSTANCE_TYPE' :
            (sortBy == 'instanceIp') ? 'i.IP' :
            (sortBy == 'instancePort') ? 'i.PORT' :
            (sortBy == 'gwName') ? 'g.GW_NAME' :
            (sortBy == 'gwProperties') ? 'g.GW_PROPERTIES' :
            (sortBy == 'threadCount') ? 'g.THREAD_COUNT' :
            (sortBy == 'ioType') ? 'g.IO_TYPE' :
            (sortBy == 'operModeType') ? 's.OPER_MODE_TYPE' :
            (sortBy == 'systemIp') ? 's.IP' :
            (sortBy == 'systemPort') ? 's.PORT' :
            (sortBy == 'stopYn') ? 's.STOP_YN' :
            (sortBy == 'systemDesc') ? 's.SYSTEM_DESC' :
            (sortBy == 'wasInstanceStatus') ? 'l.WAS_INSTANCE_STATUS' :
            (sortBy == 'activeCountIdle') ? 'l.ACTIVE_COUNT_IDLE' :
            (sortBy == 'lastUpdateDtime') ? 'l.LAST_UPDATE_DTIME' :
            'i.INSTANCE_ID'
        "/>
        <bind name="orderDir" value="(sortDirection != null &amp;&amp; sortDirection.toUpperCase() == 'DESC') ? 'DESC' : 'ASC'"/>
        SELECT
            <include refid="GatewayStatusColumns"/>
        <include refid="GatewayStatusJoins"/>
        ORDER BY ${orderColumn} ${orderDir}
    </select>
</mapper>
