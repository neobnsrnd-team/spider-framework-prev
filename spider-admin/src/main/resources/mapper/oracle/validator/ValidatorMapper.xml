<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!--
    Validator Command Mapper (CRUD)
    - insert / update / delete / 단건 조회 (존재 확인용)
    - 목록 조회, 검색 등 Query 전용 SQL은 ValidatorQueryMapper에서 처리
-->
<mapper namespace="com.example.admin_demo.domain.validator.mapper.ValidatorMapper">

    <!-- 단건 조회 (ResponseDTO 직접 반환) -->
    <select id="selectResponseById"
            resultType="com.example.admin_demo.domain.validator.dto.ValidatorResponse">
        SELECT
            TRIM(v.VALIDATOR_ID) AS validatorId,
            TRIM(v.VALIDATOR_NAME) AS validatorName,
            TRIM(v.VALIDATOR_DESC) AS validatorDesc,
            TRIM(v.BIZ_DOMAIN) AS bizDomain,
            TRIM(v.JAVA_CLASS_NAME) AS javaClassName,
            v.USE_YN AS useYn,
            v.LAST_UPDATE_DTIME AS lastUpdateDtime,
            TRIM(v.LAST_UPDATE_USER_ID) AS lastUpdateUserId
        <include refid="fromValidator"/>
        WHERE v.VALIDATOR_ID = #{validatorId}
    </select>

    <!-- 존재 확인용 카운트 -->
    <select id="countById" resultType="int">
        SELECT COUNT(*)
        FROM FWK_VALIDATOR
        WHERE VALIDATOR_ID = #{validatorId}
    </select>

    <!-- 생성 -->
    <insert id="insert">
        INSERT INTO FWK_VALIDATOR (
            VALIDATOR_ID, VALIDATOR_NAME, VALIDATOR_DESC, BIZ_DOMAIN,
            JAVA_CLASS_NAME, USE_YN, LAST_UPDATE_DTIME, LAST_UPDATE_USER_ID
        ) VALUES (
            #{dto.validatorId},
            #{dto.validatorName, jdbcType=VARCHAR},
            #{dto.validatorDesc, jdbcType=VARCHAR},
            #{dto.bizDomain, jdbcType=VARCHAR},
            #{dto.javaClassName, jdbcType=VARCHAR},
            #{dto.useYn, jdbcType=VARCHAR},
            #{lastUpdateDtime},
            #{lastUpdateUserId}
        )
    </insert>

    <!-- 수정 -->
    <update id="update">
        UPDATE FWK_VALIDATOR
        SET VALIDATOR_NAME = #{dto.validatorName, jdbcType=VARCHAR},
            VALIDATOR_DESC = #{dto.validatorDesc, jdbcType=VARCHAR},
            BIZ_DOMAIN = #{dto.bizDomain, jdbcType=VARCHAR},
            JAVA_CLASS_NAME = #{dto.javaClassName, jdbcType=VARCHAR},
            USE_YN = #{dto.useYn, jdbcType=VARCHAR},
            LAST_UPDATE_DTIME = #{lastUpdateDtime},
            LAST_UPDATE_USER_ID = #{lastUpdateUserId}
        WHERE VALIDATOR_ID = #{validatorId}
    </update>

    <!-- 삭제 -->
    <delete id="deleteById">
        DELETE FROM FWK_VALIDATOR WHERE VALIDATOR_ID = #{validatorId}
    </delete>


    <!-- ==================== Common (merged) ==================== -->


    <!-- ==================== SQL Fragment 정의 ==================== -->

    <!-- Validator + Code JOIN ResultMap (DTO 직접 매핑) -->
    <resultMap id="ValidatorWithCodeResultMap" type="com.example.admin_demo.domain.validator.dto.ValidatorResponse">
        <id property="validatorId" column="VALIDATOR_ID"/>
        <result property="validatorName" column="VALIDATOR_NAME"/>
        <result property="validatorDesc" column="VALIDATOR_DESC"/>
        <result property="bizDomain" column="BIZ_DOMAIN"/>
        <result property="bizDomainName" column="BIZ_DOMAIN_NAME"/>
        <result property="javaClassName" column="JAVA_CLASS_NAME"/>
        <result property="useYn" column="USE_YN"/>
        <result property="lastUpdateDtime" column="LAST_UPDATE_DTIME"/>
        <result property="lastUpdateUserId" column="LAST_UPDATE_USER_ID"/>
    </resultMap>

    <!-- 기본 Validator 컬럼 -->
    <sql id="baseColumns">
        v.VALIDATOR_ID, v.VALIDATOR_NAME, v.VALIDATOR_DESC, v.BIZ_DOMAIN,
        v.JAVA_CLASS_NAME, v.USE_YN, v.LAST_UPDATE_DTIME, v.LAST_UPDATE_USER_ID
    </sql>

    <!-- Validator 테이블 FROM 절 -->
    <sql id="fromValidator">
        FROM FWK_VALIDATOR v
    </sql>


    <!-- ==================== Query (merged) ==================== -->


    <!-- ==================== 공통 검색 조건 ==================== -->

    <sql id="searchConditions">
        <if test="validatorId != null and validatorId != ''">
            AND v.VALIDATOR_ID LIKE '%' || #{validatorId} || '%'
        </if>
        <if test="validatorName != null and validatorName != ''">
            AND v.VALIDATOR_NAME LIKE '%' || #{validatorName} || '%'
        </if>
        <if test="bizDomain != null and bizDomain != ''">
            AND v.BIZ_DOMAIN = #{bizDomain}
        </if>
        <if test="useYn != null and useYn != ''">
            AND v.USE_YN = #{useYn}
        </if>
    </sql>

    <!-- ==================== 목록 조회 ==================== -->

    <!-- 검색 조건으로 Validator 목록 조회 (FWK_CODE JOIN으로 bizDomainName 포함, ROWNUM 페이징) -->
    <select id="findAllWithSearch" resultMap="ValidatorWithCodeResultMap">
        SELECT * FROM (
            SELECT INNER_QRY.*, ROWNUM AS RNUM FROM (
                SELECT
                    <include refid="baseColumns"/>,
                    c.CODE_NAME AS BIZ_DOMAIN_NAME
                <include refid="fromValidator"/>
                LEFT JOIN FWK_CODE c ON c.CODE_GROUP_ID = 'FR20003' AND c.CODE = v.BIZ_DOMAIN
                <where>
                    <include refid="searchConditions"/>
                </where>
                ORDER BY
                <choose>
                    <when test="sortBy == 'validatorId'">v.VALIDATOR_ID</when>
                    <when test="sortBy == 'validatorName'">v.VALIDATOR_NAME</when>
                    <when test="sortBy == 'validatorDesc'">v.VALIDATOR_DESC</when>
                    <when test="sortBy == 'bizDomainName'">c.CODE_NAME</when>
                    <when test="sortBy == 'javaClassName'">v.JAVA_CLASS_NAME</when>
                    <when test="sortBy == 'useYn'">v.USE_YN</when>
                    <otherwise>v.VALIDATOR_ID</otherwise>
                </choose>
                <choose>
                    <when test="sortDirection == 'ASC'"> ASC</when>
                    <when test="sortDirection == 'DESC'"> DESC</when>
                    <otherwise> ASC</otherwise>
                </choose>
            ) INNER_QRY
            WHERE ROWNUM <![CDATA[<=]]> #{endRow}
        ) WHERE RNUM > #{offset}
    </select>

    <!-- 검색 조건으로 Validator 전체 건수 조회 -->
    <select id="countAllWithSearch" resultType="long">
        SELECT COUNT(*)
        <include refid="fromValidator"/>
        <where>
            <include refid="searchConditions"/>
        </where>
    </select>

    <!-- 엑셀 내보내기용 전체 조회 (페이징 없음) -->
    <select id="findAllForExport" resultMap="ValidatorWithCodeResultMap">
        SELECT
            <include refid="baseColumns"/>,
            c.CODE_NAME AS BIZ_DOMAIN_NAME
        <include refid="fromValidator"/>
        LEFT JOIN FWK_CODE c ON c.CODE_GROUP_ID = 'FR20003' AND c.CODE = v.BIZ_DOMAIN
        <where>
            <include refid="searchConditions"/>
        </where>
        ORDER BY
        <choose>
            <when test="sortBy == 'validatorId'">v.VALIDATOR_ID</when>
            <when test="sortBy == 'validatorName'">v.VALIDATOR_NAME</when>
            <when test="sortBy == 'validatorDesc'">v.VALIDATOR_DESC</when>
            <when test="sortBy == 'bizDomainName'">c.CODE_NAME</when>
            <when test="sortBy == 'javaClassName'">v.JAVA_CLASS_NAME</when>
            <when test="sortBy == 'useYn'">v.USE_YN</when>
            <otherwise>v.VALIDATOR_ID</otherwise>
        </choose>
        <choose>
            <when test="sortDirection == 'ASC'"> ASC</when>
            <when test="sortDirection == 'DESC'"> DESC</when>
            <otherwise> ASC</otherwise>
        </choose>
    </select>


</mapper>
