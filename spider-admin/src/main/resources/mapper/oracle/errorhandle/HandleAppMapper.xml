<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.admin_demo.domain.errorhandle.mapper.HandleAppMapper">

    <!-- ========== 응답 DTO용 AS 컬럼 목록 ========== -->

    <sql id="handleAppResponseColumns">
        HANDLE_APP_ID       AS handleAppId,
        HANDLE_APP_NAME     AS handleAppName,
        HANDLE_APP_DESC     AS handleAppDesc,
        LAST_UPDATE_DTIME   AS lastUpdateDtime,
        LAST_UPDATE_USER_ID AS lastUpdateUserId,
        SYS_PARAM_VALUE     AS sysParamValue,
        PARAM_DESC          AS paramDesc,
        HANDLE_APP_FILE     AS handleAppFile
    </sql>

    <!-- ========== 존재 확인 ========== -->

    <select id="countByHandleAppId" resultType="int">
        SELECT COUNT(*) FROM FWK_HANDLE_APP WHERE HANDLE_APP_ID = #{handleAppId}
    </select>

    <!-- ========== PK로 단건 조회 (응답 DTO) ========== -->

    <select id="selectResponseById"
            resultType="com.example.admin_demo.domain.errorhandle.dto.HandleAppResponse">
        SELECT
            <include refid="handleAppResponseColumns"/>
        FROM FWK_HANDLE_APP
        WHERE HANDLE_APP_ID = #{handleAppId}
    </select>

    <!-- ========== 전체 응답 DTO 목록 조회 ========== -->

    <select id="selectAllResponse"
            resultType="com.example.admin_demo.domain.errorhandle.dto.HandleAppResponse">
        SELECT
            <include refid="handleAppResponseColumns"/>
        FROM FWK_HANDLE_APP
        ORDER BY HANDLE_APP_NAME
    </select>

    <!-- ========== 삭제 ========== -->

    <delete id="deleteById">
        DELETE FROM FWK_HANDLE_APP WHERE HANDLE_APP_ID = #{handleAppId}
    </delete>

</mapper>
