<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.admin_demo.domain.service.mapper.FwkServiceRelationMapper">

    <!--
        resultMap: FWK_SERVICE_RELATION + FWK_COMPONENT + FWK_COMPONENT_PARAM + FWK_RELATION_PARAM
        4테이블 조인으로 1:N 구조(relation → params)를 표현하기 위해 resultMap 사용.
    -->
    <resultMap id="RelationResultMap"
               type="com.example.admin_demo.domain.service.dto.FwkServiceRelationResponse">
        <id     property="serviceId"     column="serviceId"/>
        <id     property="serviceSeqNo"  column="serviceSeqNo"/>
        <result property="componentId"   column="componentId"/>
        <result property="componentName" column="componentName"/>
        <result property="bizGroupId"    column="bizGroupId"/>
        <collection property="params"
                    ofType="com.example.admin_demo.domain.service.dto.FwkServiceRelationParamResponse">
            <id     property="paramSeqNo"  column="paramSeqNo"/>
            <result property="paramKey"    column="paramKey"/>
            <result property="paramDesc"   column="paramDesc"/>
            <result property="paramValue"  column="paramValue"/>
        </collection>
    </resultMap>

    <!-- ==================== 연결 컴포넌트 + 파라미터 조회 ==================== -->

    <select id="findRelationsByServiceId" resultMap="RelationResultMap">
        SELECT
            sr.SERVICE_ID                   AS serviceId,
            sr.SERVICE_SEQ_NO               AS serviceSeqNo,
            sr.COMPONENT_ID                 AS componentId,
            c.COMPONENT_NAME                AS componentName,
            c.BIZ_GROUP_ID                  AS bizGroupId,
            cp.PARAM_SEQ_NO                 AS paramSeqNo,
            cp.PARAM_KEY                    AS paramKey,
            cp.PARAM_DESC                   AS paramDesc,
            rp.PARAM_VALUE                  AS paramValue
        FROM FWK_SERVICE_RELATION sr
        JOIN FWK_COMPONENT c
            ON sr.COMPONENT_ID = c.COMPONENT_ID
        LEFT JOIN FWK_COMPONENT_PARAM cp
            ON sr.COMPONENT_ID = cp.COMPONENT_ID
        LEFT JOIN FWK_RELATION_PARAM rp
            ON sr.SERVICE_ID    = rp.SERVICE_ID
           AND sr.SERVICE_SEQ_NO = rp.SERVICE_SEQ_NO
           AND sr.COMPONENT_ID  = rp.COMPONENT_ID
           AND cp.PARAM_SEQ_NO  = rp.PARAM_SEQ_NO
        WHERE sr.SERVICE_ID = #{serviceId}
        ORDER BY sr.SERVICE_SEQ_NO, cp.PARAM_SEQ_NO
    </select>

    <!-- ==================== 연결 파라미터 삭제 (FK 의존 상 먼저 삭제) ==================== -->

    <delete id="deleteParamsByServiceId">
        DELETE FROM FWK_RELATION_PARAM WHERE SERVICE_ID = #{serviceId}
    </delete>

    <!-- ==================== 연결 컴포넌트 삭제 ==================== -->

    <delete id="deleteRelationsByServiceId">
        DELETE FROM FWK_SERVICE_RELATION WHERE SERVICE_ID = #{serviceId}
    </delete>

    <!-- ==================== 연결 컴포넌트 배치 등록 (Oracle DUAL UNION ALL) ==================== -->

    <insert id="insertRelationBatch">
        INSERT INTO FWK_SERVICE_RELATION (SERVICE_ID, SERVICE_SEQ_NO, COMPONENT_ID, LAST_UPDATE_DTIME)
        SELECT A.* FROM (
            <foreach collection="relations" item="item" separator=" UNION ALL ">
                SELECT
                    #{serviceId},
                    #{item.serviceSeqNo},
                    #{item.componentId},
                    #{lastUpdateDtime}
                FROM DUAL
            </foreach>
        ) A
    </insert>

    <!-- ==================== 연결 파라미터 배치 등록 (Oracle DUAL UNION ALL) ==================== -->

    <insert id="insertRelationParamBatch">
        INSERT INTO FWK_RELATION_PARAM (SERVICE_ID, SERVICE_SEQ_NO, COMPONENT_ID, PARAM_SEQ_NO, PARAM_VALUE)
        SELECT A.* FROM (
            <foreach collection="params" item="item" separator=" UNION ALL ">
                SELECT
                    #{serviceId},
                    #{item.serviceSeqNo},
                    #{item.componentId},
                    #{item.paramSeqNo},
                    #{item.paramValue, jdbcType=VARCHAR}
                FROM DUAL
            </foreach>
        ) A
    </insert>

</mapper>
