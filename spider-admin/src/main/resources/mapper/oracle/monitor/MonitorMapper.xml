<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.admin_demo.domain.monitor.mapper.MonitorMapper">

    <!-- 생성 -->
    <insert id="insertMonitor">
        INSERT INTO FWK_MONITOR (
            MONITOR_ID, MONITOR_NAME, MONITOR_QUERY, ALERT_CONDITION,
            ALERT_MESSAGE, REFRESH_TERM, DETAIL_QUERY, USE_YN,
            LAST_UPDATE_DTIME, LAST_UPDATE_USER_ID
        ) VALUES (
            #{dto.monitorId},
            #{dto.monitorName},
            #{dto.monitorQuery, jdbcType=VARCHAR},
            #{dto.alertCondition, jdbcType=VARCHAR},
            #{dto.alertMessage, jdbcType=VARCHAR},
            #{dto.refreshTerm, jdbcType=VARCHAR},
            #{dto.detailQuery, jdbcType=VARCHAR},
            #{dto.useYn, jdbcType=VARCHAR},
            #{lastUpdateDtime},
            #{lastUpdateUserId}
        )
    </insert>

    <!-- 수정 (MONITOR_ID 조건부 변경) -->
    <update id="updateMonitor">
        UPDATE FWK_MONITOR
        <set>
            <if test="updateMonitorId">
                MONITOR_ID = #{dto.monitorId},
            </if>
            MONITOR_NAME = #{dto.monitorName},
            MONITOR_QUERY = #{dto.monitorQuery, jdbcType=VARCHAR},
            ALERT_CONDITION = #{dto.alertCondition, jdbcType=VARCHAR},
            ALERT_MESSAGE = #{dto.alertMessage, jdbcType=VARCHAR},
            REFRESH_TERM = #{dto.refreshTerm, jdbcType=VARCHAR},
            DETAIL_QUERY = #{dto.detailQuery, jdbcType=VARCHAR},
            USE_YN = #{dto.useYn, jdbcType=VARCHAR},
            LAST_UPDATE_DTIME = #{lastUpdateDtime},
            LAST_UPDATE_USER_ID = #{lastUpdateUserId}
        </set>
        WHERE MONITOR_ID = #{oldMonitorId}
    </update>

    <!-- 삭제 -->
    <delete id="deleteById">
        DELETE FROM FWK_MONITOR WHERE MONITOR_ID = #{monitorId}
    </delete>

    <!-- 존재 확인 (중복 체크용) -->
    <select id="countByMonitorId" resultType="int">
        SELECT COUNT(*) FROM FWK_MONITOR WHERE MONITOR_ID = #{monitorId}
    </select>


    <!-- ==================== Common ==================== -->


    <!-- Monitor DTO ResultMap (DTO용 - String 타입) -->
    <resultMap id="MonitorResponseResultMap" type="com.example.admin_demo.domain.monitor.dto.MonitorResponse">
        <id property="monitorId" column="MONITOR_ID"/>
        <result property="monitorName" column="MONITOR_NAME"/>
        <result property="monitorQuery" column="MONITOR_QUERY"/>
        <result property="alertCondition" column="ALERT_CONDITION"/>
        <result property="alertMessage" column="ALERT_MESSAGE"/>
        <result property="refreshTerm" column="REFRESH_TERM"/>
        <result property="detailQuery" column="DETAIL_QUERY"/>
        <result property="useYn" column="USE_YN"/>
        <result property="lastUpdateDtime" column="LAST_UPDATE_DTIME"/>
        <result property="lastUpdateUserId" column="LAST_UPDATE_USER_ID"/>
    </resultMap>

    <!-- ==================== SQL Fragment 정의 ==================== -->

    <!-- 기본 Monitor 컬럼 -->
    <sql id="baseColumns">
        m.MONITOR_ID, m.MONITOR_NAME, m.MONITOR_QUERY, m.ALERT_CONDITION,
        m.ALERT_MESSAGE, m.REFRESH_TERM, m.DETAIL_QUERY, m.USE_YN,
        m.LAST_UPDATE_DTIME, m.LAST_UPDATE_USER_ID
    </sql>

    <!-- Monitor 테이블 FROM 절 -->
    <sql id="fromMonitor">
        FROM FWK_MONITOR m
    </sql>


    <!-- ==================== Query ==================== -->


    <!-- ==================== 목록 조회 ==================== -->

    <!-- 전체 모니터 목록 (등록순 정렬) -->
    <select id="findAll" resultMap="MonitorResponseResultMap">
        SELECT <include refid="baseColumns"/>
        <include refid="fromMonitor"/>
        ORDER BY m.MONITOR_ID ASC
    </select>

    <!-- 검색 조건 공통 SQL Fragment -->
    <sql id="searchConditions">
        <if test="searchValue != null and searchValue != ''">
            <choose>
                <when test="searchField == 'monitorId'">
                    AND m.MONITOR_ID LIKE '%' || #{searchValue} || '%'
                </when>
                <when test="searchField == 'monitorName'">
                    AND m.MONITOR_NAME LIKE '%' || #{searchValue} || '%'
                </when>
            </choose>
        </if>

        <if test="useYnFilter != null and useYnFilter != ''">
            AND m.USE_YN = #{useYnFilter}
        </if>
    </sql>

    <!-- 검색 조건 목록 조회 (네이티브 ROWNUM 페이징) -->
    <select id="findAllWithSearch" resultMap="MonitorResponseResultMap">
        SELECT * FROM (
            SELECT INNER_QRY.*, ROWNUM AS RNUM FROM (
                SELECT <include refid="baseColumns"/>
                <include refid="fromMonitor"/>
                <where>
                    <include refid="searchConditions"/>
                </where>
                ORDER BY
                <choose>
                    <when test="sortBy == 'monitorId'">UPPER(m.MONITOR_ID)</when>
                    <when test="sortBy == 'monitorName'">UPPER(m.MONITOR_NAME)</when>
                    <when test="sortBy == 'monitorQuery'">UPPER(m.MONITOR_QUERY)</when>
                    <when test="sortBy == 'refreshTerm'">m.REFRESH_TERM</when>
                    <when test="sortBy == 'useYn'">m.USE_YN</when>
                    <when test="sortBy == 'lastUpdateDtime'">m.LAST_UPDATE_DTIME</when>
                    <otherwise>m.LAST_UPDATE_DTIME</otherwise>
                </choose>
                <choose>
                    <when test="sortDirection == 'ASC'"> ASC</when>
                    <when test="sortDirection == 'DESC'"> DESC</when>
                    <otherwise> DESC</otherwise>
                </choose>
            ) INNER_QRY
            WHERE ROWNUM <![CDATA[<=]]> #{endRow}
        ) WHERE RNUM > #{offset}
    </select>

    <!-- 검색 조건 카운트 -->
    <select id="countAllWithSearch" resultType="long">
        SELECT COUNT(*)
        <include refid="fromMonitor"/>
        <where>
            <include refid="searchConditions"/>
        </where>
    </select>

    <!-- ==================== 단건 조회 ==================== -->

    <!-- 모니터 ID로 조회 (상세 조회용) -->
    <select id="findById" resultMap="MonitorResponseResultMap">
        SELECT <include refid="baseColumns"/>
        <include refid="fromMonitor"/>
        WHERE m.MONITOR_ID = #{monitorId}
    </select>

    <!-- ==================== 집계 ==================== -->

    <!-- 전체 모니터 수 -->
    <select id="countAll" resultType="long">
        SELECT COUNT(*) FROM FWK_MONITOR
    </select>

    <!-- 사용 중인 모니터 수 -->
    <select id="countActive" resultType="long">
        SELECT COUNT(*) FROM FWK_MONITOR WHERE USE_YN = 'Y'
    </select>


</mapper>
