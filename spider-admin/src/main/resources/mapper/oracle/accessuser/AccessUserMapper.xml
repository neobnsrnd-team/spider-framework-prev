<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.admin_demo.domain.accessuser.mapper.AccessUserMapper">

    <!--
        중지거래 접근허용자 Mapper
        - 데이터 변경(insert, update, delete) 및 조회
    -->

    <!-- ========== 중지거래 접근허용자 생성 ========== -->

    <insert id="insertAccessUser">
        INSERT INTO FWK_ACCESS_USER (
            TRX_ID,
            GUBUN_TYPE,
            CUST_USER_ID,
            USE_YN,
            LAST_UPDATE_DTIME,
            LAST_UPDATE_USER_ID
        ) VALUES (
            #{dto.trxId},
            #{dto.gubunType},
            #{dto.custUserId},
            #{dto.useYn},
            #{lastUpdateDtime},
            #{lastUpdateUserId}
        )
    </insert>

    <!-- ========== 중지거래 접근허용자 수정 ========== -->

    <update id="updateAccessUser">
        UPDATE FWK_ACCESS_USER
        SET
            USE_YN = #{dto.useYn},
            LAST_UPDATE_DTIME = #{lastUpdateDtime},
            LAST_UPDATE_USER_ID = #{lastUpdateUserId}
        WHERE GUBUN_TYPE = #{dto.gubunType}
          AND TRX_ID = #{dto.trxId}
          AND CUST_USER_ID = #{dto.custUserId}
    </update>

    <!-- ========== 중지거래 접근허용자 삭제 ========== -->

    <delete id="deleteAccessUser">
        DELETE FROM FWK_ACCESS_USER
        WHERE GUBUN_TYPE = #{gubunType}
          AND TRX_ID = #{trxId}
          AND CUST_USER_ID = #{custUserId}
    </delete>

    <!-- ========== 복합 PK 존재 여부 확인 ========== -->

    <select id="existsByPk" resultType="int">
        SELECT COUNT(*)
        FROM FWK_ACCESS_USER
        WHERE GUBUN_TYPE = #{gubunType}
          AND TRX_ID = #{trxId}
          AND CUST_USER_ID = #{custUserId}
    </select>

    <!-- ========== 복합 PK로 단건 조회 (응답 DTO) ========== -->

    <select id="selectResponseByPk"
            resultType="com.example.admin_demo.domain.accessuser.dto.AccessUserResponse">
        SELECT
            <include refid="accessUserResponseColumns"/>
        <include refid="fromAccessUser"/>
        WHERE GUBUN_TYPE = #{gubunType}
          AND TRX_ID = #{trxId}
          AND CUST_USER_ID = #{custUserId}
    </select>


    <!-- ==================== Common definitions ==================== -->


    <!-- ========== SQL Fragment (응답 DTO용 AS 컬럼 목록) ========== -->

    <sql id="accessUserResponseColumns">
        TRX_ID            AS trxId,
        GUBUN_TYPE        AS gubunType,
        CUST_USER_ID      AS custUserId,
        USE_YN            AS useYn,
        LAST_UPDATE_DTIME AS lastUpdateDtime,
        LAST_UPDATE_USER_ID AS lastUpdateUserId
    </sql>

    <!-- ========== SQL Fragment (FROM 절) ========== -->

    <sql id="fromAccessUser">
        FROM FWK_ACCESS_USER
    </sql>


    <!-- ==================== Query operations ==================== -->


    <!-- ========== 전체 목록 조회 ========== -->

    <select id="findAll"
            resultType="com.example.admin_demo.domain.accessuser.dto.AccessUserResponse">
        SELECT
            <include refid="accessUserResponseColumns"/>
        <include refid="fromAccessUser"/>
        ORDER BY GUBUN_TYPE, TRX_ID, CUST_USER_ID
    </select>

    <!-- ========== 검색 조건 공통 SQL Fragment ========== -->

    <sql id="searchConditions">
        <if test="trxId != null and trxId != ''">
            AND TRX_ID LIKE '%' || #{trxId} || '%'
        </if>
        <if test="gubunType != null and gubunType != ''">
            AND GUBUN_TYPE = #{gubunType}
        </if>
        <if test="custUserId != null and custUserId != ''">
            AND CUST_USER_ID LIKE '%' || #{custUserId} || '%'
        </if>
    </sql>

    <!-- ========== 검색 조건에 맞는 목록 조회 (네이티브 ROWNUM 페이징) ========== -->

    <select id="findAllWithSearch"
            resultType="com.example.admin_demo.domain.accessuser.dto.AccessUserResponse">
        SELECT * FROM (
            SELECT INNER_QRY.*, ROWNUM AS RNUM FROM (
                SELECT
                    <include refid="accessUserResponseColumns"/>
                <include refid="fromAccessUser"/>
                <where>
                    <include refid="searchConditions"/>
                </where>
                ORDER BY
                <choose>
                    <when test="sortBy == 'gubunType'">UPPER(GUBUN_TYPE)</when>
                    <when test="sortBy == 'trxId'">UPPER(TRX_ID)</when>
                    <when test="sortBy == 'custUserId'">UPPER(CUST_USER_ID)</when>
                    <when test="sortBy == 'useYn'">USE_YN</when>
                    <otherwise>GUBUN_TYPE, TRX_ID, CUST_USER_ID</otherwise>
                </choose>
                <choose>
                    <when test="sortDirection == 'ASC'"> ASC</when>
                    <when test="sortDirection == 'DESC'"> DESC</when>
                    <otherwise> ASC</otherwise>
                </choose>
            ) INNER_QRY
            WHERE ROWNUM <![CDATA[<=]]> #{endRow}
        ) WHERE RNUM > #{offset}
    </select>

    <!-- ========== 검색 조건 카운트 ========== -->

    <select id="countAllWithSearch" resultType="long">
        SELECT COUNT(*)
        <include refid="fromAccessUser"/>
        <where>
            <include refid="searchConditions"/>
        </where>
    </select>


</mapper>
