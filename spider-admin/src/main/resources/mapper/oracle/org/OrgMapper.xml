<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.admin_demo.domain.org.mapper.OrgMapper">

    <!-- ==================== 공통 SQL fragments ==================== -->

    <sql id="orgResponseColumns">
        o.ORG_ID       AS orgId,
        o.ORG_NAME     AS orgName,
        o.ORG_DESC     AS orgDesc,
        o.START_TIME   AS startTime,
        o.END_TIME     AS endTime,
        o.XML_ROOT_TAG AS xmlRootTag
    </sql>

    <sql id="fromOrg">
        FROM FWK_ORG o
    </sql>


    <!-- ==================== Command ==================== -->

    <select id="selectResponseById"
            resultType="com.example.admin_demo.domain.org.dto.OrgResponse">
        SELECT
            <include refid="orgResponseColumns"/>
        <include refid="fromOrg"/>
        WHERE o.ORG_ID = #{orgId}
    </select>

    <select id="countByOrgId" resultType="int">
        SELECT COUNT(*) FROM FWK_ORG WHERE ORG_ID = #{orgId}
    </select>

    <insert id="insertOrg">
        INSERT INTO FWK_ORG (
            ORG_ID,
            ORG_NAME,
            ORG_DESC,
            START_TIME,
            END_TIME,
            XML_ROOT_TAG
        ) VALUES (
            #{dto.orgId},
            #{dto.orgName},
            #{dto.orgDesc, jdbcType=VARCHAR},
            #{dto.startTime},
            #{dto.endTime},
            #{dto.xmlRootTag, jdbcType=VARCHAR}
        )
    </insert>

    <update id="updateOrg">
        UPDATE FWK_ORG
        SET
            ORG_NAME = #{dto.orgName},
            ORG_DESC = #{dto.orgDesc, jdbcType=VARCHAR},
            START_TIME = #{dto.startTime},
            END_TIME = #{dto.endTime},
            XML_ROOT_TAG = #{dto.xmlRootTag, jdbcType=VARCHAR}
        WHERE ORG_ID = #{dto.orgId}
    </update>

    <delete id="deleteOrgById">
        DELETE FROM FWK_ORG
        WHERE ORG_ID = #{orgId}
    </delete>


    <!-- ==================== Query ==================== -->

    <!-- 전체 기관 목록 조회 (select box용) -->
    <select id="findAll" resultType="com.example.admin_demo.domain.org.dto.OrgResponse">
        SELECT
            ORG_ID       AS orgId,
            ORG_NAME     AS orgName,
            ORG_DESC     AS orgDesc,
            START_TIME   AS startTime,
            END_TIME     AS endTime,
            XML_ROOT_TAG AS xmlRootTag
        FROM FWK_ORG
        ORDER BY ORG_ID
    </select>

    <!-- 전체 기관 목록 조회 (OrgResponse) -->
    <select id="findAllResponse" resultType="com.example.admin_demo.domain.org.dto.OrgResponse">
        SELECT
            <include refid="orgResponseColumns"/>
        <include refid="fromOrg"/>
        ORDER BY o.ORG_ID
    </select>

    <select id="findBySearchPaging" resultType="com.example.admin_demo.domain.org.dto.OrgResponse">
        <bind name="orderColumn" value="
            (sortBy == 'orgId') ? 'o.ORG_ID' :
            (sortBy == 'orgName') ? 'o.ORG_NAME' :
            (sortBy == 'orgDesc') ? 'o.ORG_DESC' :
            (sortBy == 'startTime') ? 'o.START_TIME' :
            (sortBy == 'endTime') ? 'o.END_TIME' :
            (sortBy == 'xmlRootTag') ? 'o.XML_ROOT_TAG' :
            'o.ORG_ID'
        "/>
        <bind name="orderDir" value="(sortDirection != null &amp;&amp; sortDirection.toUpperCase() == 'DESC') ? 'DESC' : 'ASC'"/>
        SELECT * FROM (
            SELECT
                <include refid="orgResponseColumns"/>,
                ROW_NUMBER() OVER (
                    ORDER BY ${orderColumn} ${orderDir}
                ) AS RN
            <include refid="fromOrg"/>
            <where>
                <choose>
                    <when test="searchField == 'orgId' and keyword != null and keyword != ''">
                        o.ORG_ID LIKE '%' || #{keyword} || '%'
                    </when>
                    <when test="searchField == 'orgName' and keyword != null and keyword != ''">
                        o.ORG_NAME LIKE '%' || #{keyword} || '%'
                    </when>
                    <otherwise>
                        1 = 1
                    </otherwise>
                </choose>
            </where>
        )
        WHERE RN BETWEEN #{offset} + 1 AND #{offset} + #{limit}
        ORDER BY RN
    </select>

    <select id="countBySearch" resultType="long">
        SELECT COUNT(*)
        FROM FWK_ORG
        <where>
            <choose>
                <when test="searchField == 'orgId' and keyword != null and keyword != ''">
                    ORG_ID LIKE '%' || #{keyword} || '%'
                </when>
                <when test="searchField == 'orgName' and keyword != null and keyword != ''">
                    ORG_NAME LIKE '%' || #{keyword} || '%'
                </when>
                <otherwise>
                    1 = 1
                </otherwise>
            </choose>
        </where>
    </select>

    <select id="findAllForExport" resultType="com.example.admin_demo.domain.org.dto.OrgResponse">
        <bind name="orderColumn" value="
            (sortBy == 'orgId') ? 'o.ORG_ID' :
            (sortBy == 'orgName') ? 'o.ORG_NAME' :
            (sortBy == 'orgDesc') ? 'o.ORG_DESC' :
            (sortBy == 'startTime') ? 'o.START_TIME' :
            (sortBy == 'endTime') ? 'o.END_TIME' :
            (sortBy == 'xmlRootTag') ? 'o.XML_ROOT_TAG' :
            'o.ORG_ID'
        "/>
        <bind name="orderDir" value="(sortDirection != null &amp;&amp; sortDirection.toUpperCase() == 'DESC') ? 'DESC' : 'ASC'"/>
        SELECT
            <include refid="orgResponseColumns"/>
        <include refid="fromOrg"/>
        <where>
            <choose>
                <when test="searchField == 'orgId' and keyword != null and keyword != ''">
                    o.ORG_ID LIKE '%' || #{keyword} || '%'
                </when>
                <when test="searchField == 'orgName' and keyword != null and keyword != ''">
                    o.ORG_NAME LIKE '%' || #{keyword} || '%'
                </when>
                <otherwise>
                    1 = 1
                </otherwise>
            </choose>
        </where>
        ORDER BY ${orderColumn} ${orderDir}
    </select>

</mapper>
