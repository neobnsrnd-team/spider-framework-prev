<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!--
    TransDataTimes Command Mapper
    - 단건 조회 (존재 확인용)
    - READ-ONLY 도메인이므로 insert/update/delete 없음
-->
<mapper namespace="com.example.admin_demo.domain.transdata.mapper.TransDataTimesMapper">

    <!-- ==================== Common definitions ==================== -->

    <sql id="baseColumns">
        t.TRAN_SEQ, t.USER_ID, t.TRAN_TIME, t.TRAN_RESULT, t.TRAN_REASON
    </sql>

    <sql id="fromTransDataTimes">
        FROM FWK_TRANS_DATA_TIMES t
    </sql>

    <!-- ==================== Command ==================== -->

    <!-- 존재 여부 확인 -->
    <select id="countByTranSeq" resultType="int">
        SELECT COUNT(*)
        <include refid="fromTransDataTimes"/>
        WHERE t.TRAN_SEQ = #{tranSeq}
    </select>


    <!-- ==================== Query (merged) ==================== -->


    <!-- ==================== 공통 SQL 조각 ==================== -->

    <sql id="searchConditionsTransTimes">
        <if test="userId != null and userId != ''">
            AND t.USER_ID LIKE '%' || #{userId} || '%'
        </if>
        <if test="tranResult != null and tranResult != ''">
            AND t.TRAN_RESULT = #{tranResult}
        </if>
    </sql>

    <sql id="orderByTransTimes">
        ORDER BY
        <choose>
            <when test="sortBy == 'tranSeq'">t.TRAN_SEQ</when>
            <when test="sortBy == 'userId'">t.USER_ID</when>
            <when test="sortBy == 'tranTime'">t.TRAN_TIME</when>
            <when test="sortBy == 'tranResult'">t.TRAN_RESULT</when>
            <when test="sortBy == 'tranReason'">t.TRAN_REASON</when>
            <when test="sortBy == 'totalCount'">totalCount</when>
            <when test="sortBy == 'failCount'">failCount</when>
            <when test="sortBy == 'successCount'">successCount</when>
            <otherwise>t.TRAN_TIME</otherwise>
        </choose>
        <choose>
            <when test="sortDirection == 'ASC'"> ASC</when>
            <when test="sortDirection == 'DESC'"> DESC</when>
            <otherwise> DESC</otherwise>
        </choose>
    </sql>

    <!-- ==================== 검색 페이징 조회 ==================== -->

    <select id="findAllWithSearch"
            resultType="com.example.admin_demo.domain.transdata.dto.TransDataTimesResponse">
        SELECT * FROM (
            SELECT INNER_QRY.*, ROWNUM AS RNUM FROM (
                SELECT
                    t.TRAN_SEQ       AS tranSeq,
                    t.USER_ID        AS userId,
                    t.TRAN_TIME      AS tranTime,
                    t.TRAN_RESULT    AS tranResult,
                    t.TRAN_REASON    AS tranReason,
                    NVL(SUM(CASE WHEN h.TRAN_RESULT = 'S' THEN 1 ELSE 0 END), 0) AS successCount,
                    NVL(SUM(CASE WHEN h.TRAN_RESULT = 'F' THEN 1 ELSE 0 END), 0) AS failCount,
                    NVL(COUNT(h.TRAN_RESULT), 0) AS totalCount
                FROM FWK_TRANS_DATA_TIMES t
                LEFT JOIN FWK_TRANS_DATA_HIS h ON h.TRAN_SEQ = t.TRAN_SEQ
                WHERE 1=1
                <include refid="searchConditionsTransTimes"/>
                GROUP BY
                    t.TRAN_SEQ,
                    t.USER_ID,
                    t.TRAN_TIME,
                    t.TRAN_RESULT,
                    t.TRAN_REASON
                <include refid="orderByTransTimes"/>
            ) INNER_QRY
            WHERE ROWNUM &lt;= #{endRow}
        )
        WHERE RNUM &gt; #{offset}
    </select>

    <!-- ==================== 엑셀 내보내기용 전체 조회 ==================== -->

    <select id="findAllForExport"
            resultType="com.example.admin_demo.domain.transdata.dto.TransDataTimesResponse">
        SELECT
            t.TRAN_SEQ       AS tranSeq,
            t.USER_ID        AS userId,
            t.TRAN_TIME      AS tranTime,
            t.TRAN_RESULT    AS tranResult,
            t.TRAN_REASON    AS tranReason,
            NVL(SUM(CASE WHEN h.TRAN_RESULT = 'S' THEN 1 ELSE 0 END), 0) AS successCount,
            NVL(SUM(CASE WHEN h.TRAN_RESULT = 'F' THEN 1 ELSE 0 END), 0) AS failCount,
            NVL(COUNT(h.TRAN_RESULT), 0) AS totalCount
        FROM FWK_TRANS_DATA_TIMES t
        LEFT JOIN FWK_TRANS_DATA_HIS h ON h.TRAN_SEQ = t.TRAN_SEQ
        WHERE 1=1
        <include refid="searchConditionsTransTimes"/>
        GROUP BY
            t.TRAN_SEQ,
            t.USER_ID,
            t.TRAN_TIME,
            t.TRAN_RESULT,
            t.TRAN_REASON
        <include refid="orderByTransTimes"/>
    </select>

    <!-- 검색 조건 건수 조회 -->
    <select id="countAllWithSearch" resultType="long">
        SELECT COUNT(*) FROM (
            SELECT t.TRAN_SEQ
            FROM FWK_TRANS_DATA_TIMES t
            WHERE 1=1
            <include refid="searchConditionsTransTimes"/>
        )
    </select>

    <!-- tranSeq 기준 이행 기본 정보 조회 -->
    <select id="findDetailByTranSeq"
            resultType="com.example.admin_demo.domain.transdata.dto.TransDataDetailResponse">
        SELECT
            t.TRAN_SEQ    AS tranSeq,
            t.TRAN_RESULT AS tranResult,
            t.TRAN_REASON AS tranReason
        FROM FWK_TRANS_DATA_TIMES t
        WHERE t.TRAN_SEQ = #{tranSeq}
    </select>


</mapper>
