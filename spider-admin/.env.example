# =============================================================
# 환경변수 설정 예시
#
# 사용 방법:
#   1. 이 파일을 복사하여 .env 로 저장 (git 추적 제외됨)
#   2. 아래 값을 실제 환경 정보로 채워 넣기
#   3. IDE 또는 터미널에서 .env 를 로드한 뒤 애플리케이션 실행
#
# .env 로드 방법:
#   - IntelliJ: EnvFile 플러그인 또는 Run Configuration → Environment variables
#   - 터미널: source .env && mvn spring-boot:run (bash)
#
# CI (GitHub Actions):
#   GitHub Secrets에 동일한 키 이름으로 등록
#   Settings → Secrets and variables → Actions → New repository secret
# =============================================================

# === Database (Oracle/MySQL 공용) ===
# Oracle 예시:
DB_URL=jdbc:oracle:thin:@localhost:1521:XE
# MySQL 예시:
# DB_URL=jdbc:mysql://localhost:3306/spider?useSSL=false&serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_USERNAME=your_username
DB_PASSWORD=your_password
DB_SCHEMA=YOUR_SCHEMA

# === App ===
APP_TITLE=Spider Admin

# === Demo 연동 (미리보기) ===
DEMO_FRONTEND_URL=http://localhost:5173

# === Security ===
REMEMBER_ME_KEY=your-remember-me-secret
AUTHORITY_SOURCE=user-menu

# === Log Destinations ===
LOG_DEST_CONSOLE=true
LOG_DEST_H2=false
LOG_DEST_LOGSTASH=false
LOG_DEST_RDB_ACCESS=true
LOG_DEST_RDB_ERROR=true
LOGSTASH_HOST=localhost
LOGSTASH_PORT=5000

# === CMS ===
# cmsUser 역할 사용자가 /cms 접근 시 이동할 외부 CMS 서버 URL
CMS_USER_URL=http://localhost:3001/
# CMS 승인 관리 미리보기 URL (포트 없음)
CMS_PREVIEW_URL=http://133.186.135.23

# === CMS Deploy ===
CMS_APP_BASE_URL=http://localhost:3000/cms
# CMS push API URL — HTML 조립·파일 저장·이력 기록을 CMS가 담당
CMS_DEPLOY_PUSH_URL=http://133.186.135.23/cms/api/deploy/push
CMS_DEPLOY_SECRET=your-deploy-secret-token
# 배포된 파일 URL 구성용 (운영 환경에서 HTTPS 사용 시 변경)
CMS_DEPLOYED_PROTOCOL=http
CMS_DEPLOYED_PATH_PREFIX=/deployed
# 만료 페이지 HTML 취득 URL
CMS_DEPLOY_EXPIRED_HTML_URL=http://133.186.135.23:3001/cms/system/page-expired.html

# === CMS Builder (미승인 이미지 업로드, 내부망 서버-투-서버) ===
CMS_BUILDER_BASE_URL=http://133.186.135.23
# 미설정 시 기본값 사용 — 경로·타임아웃이 달라지는 경우에만 선언
# CMS_BUILDER_UPLOAD_PATH=/cms/api/builder/upload
# CMS_BUILDER_CONNECT_TIMEOUT=5
# CMS_BUILDER_READ_TIMEOUT=60
# CMS_BUILDER_DEPLOY_CONNECT_TIMEOUT=5
# CMS_BUILDER_DEPLOY_READ_TIMEOUT=10

# === React CMS Deploy (승인 후 배포 전략) ===
# --- local 모드 경로·이력 설정 ---
# 미설정 시 application.yml 기본값 사용
# REACT_DEPLOY_LOCAL_COMPONENT_DIR=../demo/front/src/reactcms/generated
# REACT_DEPLOY_LOCAL_CONTAINER_DIR=../demo/front/src/reactcms/containers
# REACT_DEPLOY_LOCAL_INSTANCE_ID=demo-local-react

# === Reload ===
# 로그 레벨 저장 시 자동 Reload 대상 WAS 그룹 (FWK_WAS_GROUP.WAS_GROUP_ID)
RELOAD_DEFAULT_GROUP=POC_HNC_GROUP

# === TCP 포트 설정 ===
# Admin TCP 서버 포트 (spider-link가 관리 명령 수신)
TCP_SERVER_PORT=9999
# batch-was TCP·HTTP 포트
BATCH_WAS_TCP_PORT=9998
BATCH_WAS_HTTP_PORT=8081
# biz-channel 내장 TCP 서버 (긴급공지 커맨드 전송 대상)
BIZ_CHANNEL_TCP_HOST=localhost
BIZ_CHANNEL_TCP_PORT=19400

# === spider-link HTTP (Admin → SQL 리로드·로그레벨 변경) ===
# 미설정 시 기본값: localhost:8082
SPIDERLINK_RELOAD_URL=http://localhost:8082/api/internal/sql/reload
SPIDERLINK_LOG_LEVEL_URL=http://localhost:8082/api/internal/log

# === Test (E2E/API) ===
# E2E 테스트 계정은 e2e/docker/e2e-seed.sql에서 Oracle 컨테이너에 직접 시드.
# e2e/fixtures/test-accounts.ts 참조. 별도 환경변수 불필요.
